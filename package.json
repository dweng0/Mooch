{
  "name": "interview-copilot",
  "version": "0.0.1",
  "description": "Live interview assistant with AI-powered answer suggestions",
  "author": "Interview Copilot Team <jmartinsmith@gmail.com>",
  "homepage": "https://mooch.run",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "dev:watch": "nodemon",
    "build": "electron-vite build",
    "preview": "electron-vite preview -- --no-sandbox",
    "package": "electron-builder",
    "package:linux": "electron-builder --linux && npm run copy-binaries",
    "package:win": "electron-builder --win && npm run copy-binaries",
    "package:mac": "electron-builder --mac && npm run copy-binaries",
    "copy-binaries": "mkdir -p web/public/downloads && cp -f dist/*.{AppImage,exe,dmg} web/public/downloads/ 2>/dev/null || true",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "i18next": "^25.8.13",
    "lucide-react": "^0.575.0",
    "react-i18next": "^16.5.4",
    "socket.io-client": "^4.8.3",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@tailwindcss/vite": "^4.0.6",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.0.18",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "happy-dom": "^20.7.0",
    "nodemon": "^3.1.11",
    "openai": "^4.82.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
